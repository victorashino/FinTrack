<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Base.Theme.FinTrack" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/black</item>
        <item name="colorPrimaryVariant">@color/black</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/water_blue</item>
        <item name="colorSecondaryVariant">@color/ocean_blue</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Theme.FinTrack" parent="Base.Theme.FinTrack" />

    <style name="TextSemiBold" parent="Widget.AppCompat.TextView">
        <item name="fontFamily">@font/josefin_sans_semibold</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="TextNormal" parent="Widget.AppCompat.TextView">
        <item name="fontFamily">@font/josefin_sans</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="Button" parent="Widget.AppCompat.Button">
        <item name="fontFamily">@font/josefin_sans_semibold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">24sp</item>
        <item name="android:background">@drawable/button_shape</item>
    </style>

</resources>