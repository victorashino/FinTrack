            android:layout_height="wrap_content"
            android:layout_alignStart="@+id/iconWaterDrop"
            android:layout_alignTop="@id/iconWaterDrop"
            android:layout_alignEnd="@+id/iconWaterDrop"
            android:layout_alignBottom="@id/iconWaterDrop"
            android:layout_gravity="center"
            android:contentDescription="@string/borda"
            android:src="@drawable/border_icon" />

        <ImageView
            android:id="@+id/iconCreditCard"
