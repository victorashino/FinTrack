        <ImageView
            android:id="@+id/borderGameControl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignStart="@+id/iconGameControl"
            android:layout_alignTop="@id/iconGameControl"
            android:layout_alignEnd="@+id/iconGameControl"
            android:layout_alignBottom="@id/iconGameControl"
