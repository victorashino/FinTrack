            android:src="@drawable/check_white"
            android:visibility="invisible" />

        <View
            android:id="@+id/colorBlack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentTop="true"
            android:layout_marginTop="0dp"
