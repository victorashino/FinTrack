        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textCategoryIcon"
        tools:ignore="UsingOnClickInXml">

        <ImageView
            android:id="@+id/iconKey"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:contentDescription="@string/icon_key"
            android:src="@drawable/ic_key" />

        <ImageView
            android:id="@+id/borderKey"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignStart="@+id/iconKey"
            android:layout_alignTop="@id/iconKey"
            android:layout_alignEnd="@+id/iconKey"
            android:layout_alignBottom="@id/iconKey"
            android:layout_gravity="center"
            android:contentDescription="@string/borda"
            android:src="@drawable/border_icon" />

        <ImageView
            android:id="@+id/iconEnergy"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentTop="true"
